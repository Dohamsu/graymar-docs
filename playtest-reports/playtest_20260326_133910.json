        "llmExtracted": [
          {
            "text": "잠긴 닻 선술집 내부는 꺼질듯한 촛불과 에일 냄새가 뒤섞여 무거운 분위기",
            "turnNo": 0,
            "category": "PLACE_DETAIL",
            "importance": 0.7
          },
          {
            "text": "로넨은 항만 노동 길드 서기관이며, 장부 도난 사건으로 절박한 상태",
            "turnNo": 0,
            "category": "NPC_DETAIL",
            "importance": 0.7
