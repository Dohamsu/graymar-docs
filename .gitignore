# Subprojects (separate repos)
server/
client/

# System files
.DS_Store

# Claude Code state — ignore everything except agents/commands/skills definitions
.claude/*
!.claude/agents/
!.claude/commands/
!.claude/skills/

# Content seed data is in server repo
