# Subprojects (separate repos)
server/
client/

# System files
.DS_Store

# Claude Code state — ignore everything except agents/commands/skills definitions
.claude/*
!.claude/agents/
!.claude/commands/
!.claude/skills/

# Content seed data is in server repo
# content/ is symlinked or copied — keep here for reference
.env

# Build/tooling artifacts
node_modules/
*.log
*.backup

# Playtest outputs — keep the folder via .gitkeep, drop individual reports from tracking
playtest-reports/*.json
playtest-reports/*.txt
playtest-reports/*.md
playtest-reports/**/
playtest-reports/archive/
!playtest-reports/.gitkeep

# Quartz 빌드 산출물 (content는 sync-content 스크립트로 매번 재생성)
# 동기화된 content/ 파일은 git untracked 상태로 두고 commit 하지 않음
quartz/node_modules/
quartz/public/
quartz/.quartz-cache/
.gstack/
quartz/docs/
