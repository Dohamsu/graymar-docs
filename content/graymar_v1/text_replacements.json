{
  "$schema": "https://graymar.example.com/schemas/text-replacements.v1.json",
  "description": "LLM 서술 후처리 치환 규칙 — llm-worker.service.ts 후처리에서 사용. 앱 시작 시 1회 로드.",
  "npcApproach": {
    "description": "NPC 다가오기 패턴 자동 치환 — 원칙 'NPC가 플레이어에게 다가가지 않는다'",
    "rules": [
      { "pattern": "조심스레 다가왔다", "replacement": "멀찍이 서서 당신을 지켜보고 있었다" },
      { "pattern": "조심스럽게 다가왔다", "replacement": "멀찍이 서서 당신을 주시하고 있었다" },
      { "pattern": "천천히 다가왔다", "replacement": "멀찍이 서 있었다" },
      { "pattern": "다가와 낮은 목소리로", "replacement": "멀찍이 서서 낮은 목소리로" },
      { "pattern": "다가와 말했다", "replacement": "조용히 말을 건넨다" },
      { "pattern": "다가와 조심스레", "replacement": "조용히 조심스레" },
      { "pattern": "다가오는 모습이", "replacement": "서 있는 모습이" },
      { "pattern": "걸어왔다", "replacement": "그 자리에 서 있었다" },
      { "pattern": "다가왔다", "replacement": "그 자리에 서 있었다" },
      { "pattern": "다가오며", "replacement": "그 자리에 선 채로" },
      { "pattern": "다가와", "replacement": "그 자리에 선 채로" }
    ]
  },
  "currency": {
    "description": "화폐 단위 규칙 강제 — '은화/금화/동전/닢' 금지, '골드'만 사용. 프롬프트 규칙과 일치.",
    "rules": [
      { "pattern": "동전\\s*주머니", "replacement": "가죽 주머니", "flags": "g" },
      { "pattern": "(?<![가-힣])(동전|은화|금화)(?![가-힣])", "replacement": "골드", "flags": "g" },
      { "pattern": "(\\d+)\\s*닢(?![가-힣])", "replacement": "$1골드", "flags": "g" }
    ]
  },
  "repeatKillAll": {
    "description": "관용구 남용 완전 제거 — 첫 등장부터 모두 삭제",
    "patterns": [
      "(?:약속이라도\\s*한\\s*듯이?|약속이라도\\s*한\\s*것처럼)\\s*"
    ]
  },
  "repeatSecondPlus": {
    "description": "한 턴 내 2회+ 등장 시 2번째부터 제거 (첫 등장 유지). CLAUDE.md LLM 설계 원칙의 반면교사 — 학습된 관용구 풍선효과 방지.",
    "patterns": [
      "신경질적으로\\s*밀어\\s*올리며",
      "안경테를\\s*(?:가볍게\\s*)?밀어\\s*올리며",
      "안경\\s*너머로\\s*시선을\\s*던지며",
      "숨이\\s*턱\\s*막히(?:며|고)",
      "시선을\\s*(?:아래로\\s*)?떨구며",
      "시선을\\s*피하(?:며|고)"
    ]
  },
  "compoundTitleFix": {
    "description": "복합 호칭 hallucination 제거 — '[수식어한] [수식어한] [명사] [명사]' 3+어절 연속 감지 → 마지막 2어절만 유지",
    "pattern": "(?:[가-힣]{2,6}한\\s+){2,}[가-힣]{2,6}(?:\\s+[가-힣]{2,6})*",
    "flags": "g",
    "minPartsToFix": 4,
    "keepTailWords": 2
  }
}
